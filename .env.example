# ============================================
# AI Coding Agent - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --------------------------------------------
# Telegram Bot (REQUIRED)
# --------------------------------------------
# Get from @BotFather on Telegram:
#   1. Open Telegram, search @BotFather
#   2. Send /newbot
#   3. Set bot name and username
#   4. Copy the token
TELEGRAM_BOT_TOKEN=8714940913:AAEoFEIoEf9jJG4m7ARZb6dap10SUDvWjCU

# --------------------------------------------
# Allowed Telegram User IDs (REQUIRED)
# --------------------------------------------
# Get from @userinfobot on Telegram:
#   1. Open Telegram, search @userinfobot
#   2. Send /start
#   3. Copy your numeric ID
# Comma-separated for multiple users
ALLOWED_USERS=6302853216

# --------------------------------------------
# Redis (defaults work for Docker Compose)
# --------------------------------------------
REDIS_URL=redis://redis:6379/0

# --------------------------------------------
# Gateway (defaults work for Docker Compose)
# --------------------------------------------
GATEWAY_PORT=8000

# --------------------------------------------
# Workspace
# --------------------------------------------
WORKSPACE_BASE=/opt/ai-agent/workspaces

# --------------------------------------------
# Worker (Step 3)
# --------------------------------------------
TASK_TIMEOUT=600
MEM_LIMIT=2147483648
CPU_LIMIT=1
OPENHANDS_IMAGE=docker.openhands.dev/openhands/openhands:1.7
AGENT_SERVER_IMAGE_REPOSITORY=ghcr.io/openhands/agent-server
AGENT_SERVER_IMAGE_TAG=1.19.1-python

# --------------------------------------------
# Zalo Adapter (optional — Phase 2)
# --------------------------------------------
# Set to true to enable Zalo as a second messaging channel
# First run requires QR code scan — credentials saved automatically
ZALO_ENABLED=false
ZALO_CREDENTIALS_PATH=./secrets/zalo_credentials.json
# Comma-separated Zalo user IDs allowed to use the bot
ZALO_ALLOWED_USERS=

# --------------------------------------------
# Cloudflare Tunnel (Step 6)
# --------------------------------------------
TUNNEL_ENABLED=true
DEFAULT_APP_PORT=3000

# --------------------------------------------
# LLM Router - 9Router (REQUIRED for OpenHands)
# --------------------------------------------
# 9Router provides OpenAI-compatible API with smart routing + fallback
# Dashboard: http://<server-ip>:20128
# API: http://9router:20128/v1 (from inside Docker)
NINEROUTER_PORT=20128
NINEROUTER_BASE_URL=http://9router:20128
# Get API key from 9Router Dashboard → Settings → API Keys
NINEROUTER_API_KEY=
# Model: use a combo name or provider/model format
# Examples: kr/claude-sonnet-4.5, glm/glm-4.7, if/kimi-k2-thinking
NINEROUTER_MODEL=kr/claude-sonnet-4.5
